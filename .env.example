DATABASE_URL=postgresql://user:password@host/pegasus?sslmode=require
REDIS_URL=redis://localhost:6379
SERVICE_NAME=pegasus-api
PORT=3000
CORS_ORIGIN=http://localhost:3000
SESSION_SECRET=change-me-use-a-long-random-secret
ROOT_EMAIL=root@pegasus.com
ROOT_PASSWORD=change-me-before-seeding
PUSHER_BEAMS_INSTANCE_ID=your-instance-id
PUSHER_BEAMS_PRIMARY_KEY=your-primary-key
PUSHER_BEAMS_WEB_ORIGIN=https://your-public-web-domain.com
NEXT_PUBLIC_PUSHER_BEAMS_INSTANCE_ID=your-instance-id

# En Vercel: Root Directory = packages/web. Variables en Project Settings → Environment Variables.
# Desarrollo local: pnpm dev:all (Node) o pnpm dev:vercel (emulador Vercel desde packages/web).
