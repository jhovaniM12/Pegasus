DATABASE_URL=postgresql://user:password@host/pegasus?sslmode=require
REDIS_URL=redis://localhost:6379
SERVICE_NAME=pegasus-api
PORT=3000
CORS_ORIGIN=http://localhost:3000
SESSION_SECRET=change-me-use-a-long-random-secret
ROOT_EMAIL=root@pegasus.com
ROOT_PASSWORD=change-me-before-seeding

# En Vercel: configurar DATABASE_URL y SERVICE_NAME en Project Settings → Environment Variables.
# Desarrollo local: pnpm dev (Node) o pnpm dev:vercel (emulador Vercel).
