{
  "name": "@pegasus/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typeorm": "tsx ./node_modules/typeorm/cli.js -d src/database/data-source.ts",
    "migration:generate": "tsx ./node_modules/typeorm/cli.js migration:generate src/migrations/GeneratedMigration -d src/database/data-source.ts",
    "migration:run": "tsx ./node_modules/typeorm/cli.js migration:run -d src/database/data-source.ts",
    "migration:revert": "tsx ./node_modules/typeorm/cli.js migration:revert -d src/database/data-source.ts",
    "migration:show": "tsx ./node_modules/typeorm/cli.js migration:show -d src/database/data-source.ts",
    "db:ping": "tsx src/scripts/ping-db.ts",
    "db:seed": "tsx src/scripts/seed-roles-fedequinas.ts",
    "db:seed:root": "tsx src/scripts/seed-root-user.ts",
    "db:seed:ciudades": "tsx src/scripts/seed-ciudades-fedequinas.ts",
    "db:seed:sexes": "tsx src/scripts/seed-sexes-fedequinas.ts",
    "db:seed:gaits": "tsx src/scripts/seed-gaits-fedequinas.ts",
    "db:seed:equine-types": "tsx src/scripts/seed-equine-types-fedequinas.ts",
    "db:seed:groupings": "tsx src/scripts/seed-groupings-fedequinas.ts",
    "db:seed:titles": "tsx src/scripts/seed-titles-fedequinas.ts",
    "db:seed:grades": "tsx src/scripts/seed-grades-fedequinas.ts",
    "db:seed:categories": "tsx src/scripts/seed-categories-fedequinas.ts",
    "db:seed:fairs": "tsx src/scripts/seed-fairs-fedequinas.ts",
    "db:seed:fair-entries": "tsx src/scripts/seed-fair-entries-fedequinas.ts",
    "db:seed:people": "tsx src/scripts/seed-people-fedequinas.ts",
    "db:seed:fair-staff": "tsx src/scripts/seed-fair-staff-fedequinas.ts",
    "db:seed:fair-results": "tsx src/scripts/seed-fair-results-fedequinas.ts",
    "db:seed:disqualification-reasons": "tsx src/scripts/seed-disqualification-reasons.ts"
  },
  "dependencies": {
    "ioredis": "^5.6.1",
    "pg": "^8.16.0",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.24"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
